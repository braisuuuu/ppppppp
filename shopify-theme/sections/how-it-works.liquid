<section class="sg-steps sg-section sg-section--white" data-animate>
  <div class="sg-container">
    <div class="sg-section__header">
      <h2 class="sg-section__title">{{ section.settings.title }}</h2>
    </div>

    <div class="sg-steps__grid">
      <div class="sg-steps__line" aria-hidden="true"></div>
      {% for block in section.blocks %}
        <div class="sg-steps__card" {{ block.shopify_attributes }}>
          <div class="sg-steps__number">
            <span>{{ forloop.index | prepend: '0' }}</span>
          </div>
          <h3 class="sg-steps__card-title">{{ block.settings.title }}</h3>
          <p class="sg-steps__card-text">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Cómo funciona - 3 pasos",
  "tag": "section",
  "class": "sg-steps-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título de sección",
      "default": "Rutina en solo 3 pasos"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Paso",
      "limit": 5,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Título del paso",
          "default": "Limpia"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Descripción del paso",
          "default": "Limpia tu rostro cuidadosamente."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cómo funciona - 3 pasos",
      "blocks": [
        { "type": "step", "settings": { "title": "Limpia", "description": "Limpia tu rostro cuidadosamente." } },
        { "type": "step", "settings": { "title": "Aplica", "description": "Utiliza el dermaroller siguiendo las instrucciones." } },
        { "type": "step", "settings": { "title": "Hidrata", "description": "Aplica el sérum para completar tu rutina facial." } }
      ]
    }
  ]
}
{% endschema %}
