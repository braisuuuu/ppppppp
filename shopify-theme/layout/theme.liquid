<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="format-detection" content="telephone=no">

    <title>{{ page_title }}{% unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless %}</title>

    {% if page_description %}
      <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    {{ content_for_header }}

    <link rel="stylesheet" href="{{ 'skinglow-kit.css' | asset_url }}">
    <script src="{{ 'skinglow-kit.js' | asset_url }}" defer></script>

    {% style %}
      :root {
        --color-rose-50: #fff1f2;
        --color-rose-100: #ffe4e6;
        --color-rose-200: #fecdd3;
        --color-rose-300: #fda4af;
        --color-rose-400: #fb7185;
        --color-rose-500: #f43f5e;
        --color-amber-50: #fffbeb;
        --color-amber-100: #fef3c7;
        --color-amber-200: #fde68a;
        --color-amber-300: #fcd34d;
        --color-amber-400: #fbbf24;
        --color-amber-500: #f59e0b;
        --gradient-primary: linear-gradient(135deg, #fb7185 0%, #fbbf24 100%);
        --gradient-primary-hover: linear-gradient(135deg, #f43f5e 0%, #f59e0b 100%);
        --gradient-hero: linear-gradient(135deg, #fff1f2 0%, rgba(254,243,199,0.5) 50%, #ffffff 100%);
        --gradient-offer: linear-gradient(135deg, #fb7185 0%, #f43f5e 50%, #fbbf24 100%);
        --font-body: 'Segoe UI', system-ui, -apple-system, sans-serif;
      }
    {% endstyle %}
  </head>
  <body style="font-family: var(--font-body); -webkit-font-smoothing: antialiased; margin: 0;">
    {{ content_for_layout }}
  </body>
</html>
